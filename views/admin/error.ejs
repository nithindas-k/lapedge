<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Admin Panel</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .error-container {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: #121212;
            color: #fff;
        }
        .error-card {
            background-color: #1e1e1e;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
            text-align: center;
            max-width: 500px;
            border: 1px solid #333;
        }
        .error-code {
            font-size: 72px;
            font-weight: bold;
            color: #ff5252;
            margin-bottom: 20px;
        }
        .error-message {
            font-size: 18px;
            margin-bottom: 30px;
            color: #bbb;
        }
        .btn-back {
            background-color: #ff5252;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            transition: background-color 0.2s;
        }
        .btn-back:hover {
            background-color: #e04040;
            color: white;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-card">
            <div class="error-code">⚠️</div>
            <h2>An Error Occurred</h2>
            <p class="error-message">Something went wrong while processing your request. Please go back or try again later.</p>
            <a href="/admin/dashboard" class="btn-back">Go to Dashboard</a>
        </div>
    </div>
</body>
</html>
